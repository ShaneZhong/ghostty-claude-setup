# Ghostty Terminal Config
# Based on: https://z1han.com Ghostty终端配置指南 (BravoHenry)
# Philosophy: "Designed to Disappear" — the best terminal is one you forget exists.

# ─── Font ───────────────────────────────────────────────────────────────────────
# Maple Mono NF CN: monospace + Chinese glyphs + Nerd Font icons + ligatures
# Install: brew install --cask font-maple-mono-nf-cn
font-family = "Maple Mono NF CN"
font-size = 14
font-thicken = true
font-feature = +calt
font-feature = +liga
adjust-cell-height = 3
adjust-cell-width = 1

# ─── Theme ──────────────────────────────────────────────────────────────────────
# Auto-switch with macOS dark mode: Latte (light) / Mocha (dark)
theme = light:Catppuccin Latte,dark:Catppuccin Mocha

# ─── Window: The Art of Disappearing ────────────────────────────────────────────
background-opacity = 0.88
background-blur = 30
# macos-titlebar-style = hidden  # disabled: breaks Cmd+T tab creation
window-padding-x = 12
window-padding-y = 10
window-padding-balance = true
window-padding-color = extend
window-save-state = always
window-inherit-working-directory = true
window-colorspace = display-p3
window-theme = auto

# ─── Claude Code Optimization ───────────────────────────────────────────────────
# 160x50 gives Claude Code enough room for diffs and code blocks
window-width = 160
window-height = 50
link-url = true

# ─── Cursor: Visible but Quiet ──────────────────────────────────────────────────
cursor-style = bar
cursor-style-blink = false
cursor-opacity = 1.0

# ─── Mouse & Clipboard ─────────────────────────────────────────────────────────
mouse-hide-while-typing = true
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true
focus-follows-mouse = true

# ─── Quick Terminal: Quake Mode ─────────────────────────────────────────────────
# Ctrl+` from any app — slides down from top, autohides on blur
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.12

# ─── Splits ─────────────────────────────────────────────────────────────────────
# Dim unfocused splits with Catppuccin Mocha base color
unfocused-split-fill = #1e1e2e

# ─── Shell Integration ──────────────────────────────────────────────────────────
shell-integration = detect
shell-integration-features = no-cursor
scrollback-limit = 10000000
resize-overlay = after-first
resize-overlay-position = bottom-right
resize-overlay-duration = 500ms

# ─── Security ───────────────────────────────────────────────────────────────────
# Protect against malicious paste (hidden newlines, escape sequences)
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# ─── Keybinds ───────────────────────────────────────────────────────────────────
keybind = super+shift+r=prompt_tab_title

# Leader Key — uncomment if you use tmux-style ctrl+a
# keybind = ctrl+a>h=goto_split:left
# keybind = ctrl+a>j=goto_split:bottom
# keybind = ctrl+a>k=goto_split:top
# keybind = ctrl+a>l=goto_split:right
